# Cloudflare Pages cache-policy
# HTML, JSX og JS skal ALDRI caches lenge — vi vil at PWA-en skal
# kunne plukke opp ny build raskt. Statiske assets (ikoner, logo)
# kan caches normalt.

/index.html
  Cache-Control: public, max-age=0, must-revalidate

/app/*
  Cache-Control: public, max-age=0, must-revalidate

/manifest.webmanifest
  Cache-Control: public, max-age=0, must-revalidate

/*.jsx
  Cache-Control: public, max-age=0, must-revalidate

# Fotball-appen er ren HTML/JS — samme prinsipp: ny build skal
# plukkes opp raskt. Eksplisitt charset så æøå ikke mojibakes hvis
# fila åpnes direkte eller en mellomtjener decoder etter header.
/fotball/*
  Cache-Control: public, max-age=0, must-revalidate

/fotball/*.js
  Content-Type: text/javascript; charset=utf-8

# Klubbdashboardet (/dashboard) — samme prinsipp som fotball: fersk build
# plukkes opp raskt, og eksplisitt charset så æøå i JSON/JS ikke mojibakes.
/dashboard/*
  Cache-Control: public, max-age=0, must-revalidate

/dashboard/*.js
  Content-Type: text/javascript; charset=utf-8

/dashboard/*.json
  Content-Type: application/json; charset=utf-8

# Statiske assets med fingerprint-eller-stabile-paths kan caches
/icons/*
  Cache-Control: public, max-age=86400

/logo.png
  Cache-Control: public, max-age=86400
